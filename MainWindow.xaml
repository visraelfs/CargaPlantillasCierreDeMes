<Window x:Class="CargaPlantillasCierreDeMes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CargaPlantillasCierreDeMes"
        mc:Ignorable="d"
        Title="Carga plantillas cierre de mes" Height="207" Width="629">
    <Grid>
        <Grid.ColumnDefinitions>
        </Grid.ColumnDefinitions>
        <TextBox Name="txtRutaArchivo" HorizontalAlignment="Left" Margin="22,38,0,0" IsReadOnly="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Hidden" Text="" VerticalAlignment="Top" Width="449"/>
        <Button Content="..." HorizontalAlignment="Left" Margin="471,38,0,0" VerticalAlignment="Top" Height="18" Width="26" Click="BuscarArchivo_Click"/>
        <Button Content="Subir Archivo" HorizontalAlignment="Left" Margin="512,38,0,0" VerticalAlignment="Top" Width="92" Height="18" Click="CargarArchivo_Click"/>
        <RadioButton GroupName="tipoPlantilla" Name="rbProvision" Content="Provisiones" HorizontalAlignment="Left" Margin="82,79,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.418,-0.763" IsChecked="True"/>
        <RadioButton GroupName="tipoPlantilla" Name="rbCancelaProvision" Content="Cancela Provisiones" HorizontalAlignment="Left" Margin="390,79,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.049,-0.291"/>
        <ProgressBar Name="progressBar" HorizontalAlignment="Left" Height="13" Margin="26,111,0,0" VerticalAlignment="Top" Width="542" Visibility="Hidden"/>
        <TextBlock x:Name="progressText" HorizontalAlignment="Left" Margin="26,140,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="542"/>
    </Grid>
</Window>
